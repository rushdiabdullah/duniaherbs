# Deepseek (untuk Emma chatbot)
DEEPSEEK_API_KEY=

# Unsplash (optional - untuk script fetch imej: node --env-file=.env.local scripts/fetch-unsplash-urls.mjs)
# Daftar percuma: unsplash.com/developers
# UNSPLASH_ACCESS_KEY=

# ToyyibPay — Sandbox: https://dev.toyyibpay.com | Production: https://toyyibpay.com
# Daftar → buat Category → dapat categoryCode & userSecretKey dari dashboard
TOYYIBPAY_BASE_URL=https://dev.toyyibpay.com
TOYYIBPAY_USER_SECRET_KEY=
TOYYIBPAY_CATEGORY_CODE=

# Supabase (https://app.supabase.com → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: callback URL base (e.g. https://duniaherb.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp (format: 60123456789, tanpa + atau spaces)
NEXT_PUBLIC_WHATSAPP=60123456789
